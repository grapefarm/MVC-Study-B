@model IEnumerable<WebApplication2.Models.Product>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<form method="get" asp-controller="Products" asp-action="Index" class="mb-3">
    <div class="row g-2 align-items-center">
        <!-- 關鍵字 -->
        <div class="col-auto">
            <input type="text" name="keyword" value="@ViewData["CurrentKeyword"]" class="form-control" placeholder="商品名稱..." />
            <input type="hidden" name="sortBy" value="@ViewData["CurrentSort"]" />
        </div>
        <!-- 分類下拉選單 -->
        <div class="col-auto">
            <select name="categoryId" class="form-select" asp-items="ViewBag.CategoryId">
                <option value="">-- 全部商品分類 --</option>
            </select>
        </div>
        <!-- 按鈕組 -->
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">複合搜尋</button>
            <a asp-controller="Products" asp-action="Index" class="btn btn-secondary">清除</a>
        </div>
    </div>
</form>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ProductName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.QuantityPerUnit)
            </th>
            <th>
                <a asp-action="Index"
                   asp-route-sortBy="@ViewData["PriceSortParam"]" 
                   asp-route-keyword="@ViewData["CurrentKeyword"]"
                   asp-route-categoryId="@Context.Request.Query["categoryId"]"
                >
                    單價
                </a>
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UnitsInStock)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Category)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Supplier)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ProductName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.QuantityPerUnit)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UnitPrice)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UnitsInStock)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Category.CategoryName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Supplier.CompanyName)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ProductId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ProductId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ProductId">Delete</a>
                <button type="button" class="btn btn-sm btn-danger btn-delete-fetch" data-id="@item.ProductId">
                    非同步刪除
                </button>
                <a href="#" class="btn btn-outline-warning btn-toggle-status" data-id="@item.ProductId">
                    狀態：<span class="status-text text-success">販售中</span>
                </a>
            </td>
        </tr>
}
    </tbody>
</table>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // 💡 1. 抓取外層容器（例如 tbody 或 table），只綁定一個監聽器，效能爆棚！
            document.querySelector('tbody')?.addEventListener('click', async (e) => {

                // 💡 2. 精準鎖定：只有點到帶有 .btn-delete-fetch 的按鈕才觸發
                const button = e.target.closest('.btn-delete-fetch');
                if(button){
                    if (!confirm("確定要刪除這筆商品嗎？")) return;

                    e.preventDefault(); // 擋掉預設行為
                    const id = button.getAttribute('data-id');

                    try {
                        // 💡 3. 最精簡 Fetch：刪除不需要的 Header，直球對決
                        const response = await fetch(`@Url.Action("DeleteApi", "Products")?id=${id}`, { method: 'POST' });
                        const result = await response.json();

                        // 💡 4. 原生秒殺 DOM 節點
                        if (result.success) {
                            button.closest('tr').remove();
                        } else {
                            alert(result.message || "刪除失敗！");
                        }
                    } catch (error) {
                        console.error(error);
                        alert("連線發生錯誤！");
                    }
                    return;   
                }
            

                const statusBtn = e.target.closest('.btn-toggle-status');
                if (statusBtn) {
                    e.preventDefault(); // 擋掉超連結的 # 錨點跳動

                    const id = statusBtn.getAttribute('data-id');
                    const statusSpan = statusBtn.querySelector('.status-text');

                    try {
                        const apiUrl = 'https://localhost:7194/api/ProductsApi/toggle-discontinued';

                        const response = await fetch(apiUrl, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ Id: parseInt(id) })
                        });

                        const result = await response.json();

                        // 前端免重整，動態切換畫面狀態
                        if (result.success) {
                            if (result.isDiscontinued) {
                                statusSpan.innerText = "已停售";
                                statusSpan.className = "status-text text-danger fw-bold";
                            } else {
                                statusSpan.innerText = "販售中";
                                statusSpan.className = "status-text text-success";
                            }
                        }
                    } catch (error) {
                        console.error(error);
                        alert("🚨 跨網域中央伺服器連線失敗！");
                    }
                    return; // 💡 執行完畢收工
                }
            });
        });
    </script>
}