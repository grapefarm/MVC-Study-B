@model IEnumerable<WebApplication2.Models.Product>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>
<form method="get" action="@Url.Action("Index", "Products")" class="mb-3">
    <div class="row g-2 align-items-center">
        <!-- 關鍵字 -->
        <div class="col-auto">
            <input type="text" name="keyword" value="@ViewData["CurrentKeyword"]" class="form-control" placeholder="商品名稱..." />
        </div>
        <!-- 分類下拉選單（會自動選中上次篩選的項目） -->
        <div class="col-auto">
            <select name="categoryId" class="form-select" asp-items="ViewBag.CategoryId">
                <option value="">-- 全部商品分類 --</option>
            </select>
        </div>
        <!-- 按鈕組 -->
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">複合搜尋</button>
            <a href="@Url.Action("Index", "Products")" class="btn btn-secondary">清除</a>
        </div>
    </div>
</form>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ProductName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.QuantityPerUnit)
            </th>
            <th>
                <a href="@Url.Action("Index", new { sortBy = ViewData["PriceSortParam"], keyword = ViewData["CurrentKeyword"], categoryId = Context.Request.Query["categoryId"] })" style="text-decoration: none;">
                    單價 ↕
                </a>
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UnitsInStock)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Category)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Supplier)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ProductName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.QuantityPerUnit)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UnitPrice)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UnitsInStock)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Category.CategoryName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Supplier.CompanyName)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ProductId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ProductId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ProductId">Delete</a>
                <button type="button" class="btn btn-sm btn-danger btn-delete-fetch" data-id="@item.ProductId">
                    非同步刪除
                </button>
            </td>
        </tr>
}
    </tbody>
</table>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // 1. 綁定所有帶有 .btn-delete-fetch 的按鈕
            const deleteButtons = document.querySelectorAll('.btn-delete-fetch');

            deleteButtons.forEach(button => {
                button.addEventListener('click', async (e) => {
                    // 阻止預設行為
                    e.preventDefault();

                    const id = button.getAttribute('data-id');

                    // 考場防呆：先彈出詢問視窗，避免手滑
                    if (!confirm("確定要刪除這筆商品嗎？(Fetch 異步執行)")) return;

                    try {
                        // 2. 使用現代 Fetch API 呼叫後端 API
                        const response = await fetch(`@Url.Action("DeleteApi", "Products")?id=${id}`, {
                            method: 'POST',
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        });

                        const result = await response.json();

                        if (result.success) {
                            // 3. 炫技點：網頁不重新整理，直接用 JS 找到那一行 <tr> 並讓它在畫面上消失
                            const row = button.closest('tr');
                            row.style.transition = 'all 0.5s ease';
                            row.style.opacity = '0';

                            setTimeout(() => {
                                row.remove();
                            }, 500); // 0.5秒後徹底從 DOM 移除
                        } else {
                            alert(result.message || "刪除失敗！");
                        }
                    } catch (error) {
                        console.error("錯誤:", error);
                        alert("連線發生錯誤！");
                    }
                });
            });
        });
    </script>
}